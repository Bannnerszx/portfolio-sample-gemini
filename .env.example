# Copy to .env.local and fill in. Never commit .env.local.
#
# NOTE: this file IS committed — it is the template. Never paste a real key here.

# ---------------------------------------------------------------------------
# Gemini API  (model: gemini-3.1-flash-lite — Google's cheapest)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=

# The master kill switch. Leave "false" while developing — the whole demo runs
# end to end on canned results at zero cost. Set "true" to spend real money.
DEMO_AI_ENABLED=false

# ---------------------------------------------------------------------------
# Spend caps (all optional — these are the defaults)
# ---------------------------------------------------------------------------
DEMO_RUNS_PER_VISITOR=5     # live runs per visitor, then they get canned results
DEMO_RUNS_PER_DAY=50        # global, resets at UTC midnight
DEMO_RUNS_TOTAL=500         # global lifetime ceiling (~$1.50 worst case)

# Salt for hashing visitor IPs. Set to any long random string in production —
# without it, IP hashes are guessable.
QUOTA_SALT=change-me-to-something-random

# Lets you bypass the per-visitor cap on your own machine (for screen
# recordings). Visit /ops?key=<value> once to set the cookie. Leave unset to
# disable the bypass entirely.
OWNER_DEMO_KEY=

# ---------------------------------------------------------------------------
# Anti-abuse / lockdown
# ---------------------------------------------------------------------------
# The panic button. "true" forces canned results for everyone, immediately.
DEMO_LOCKDOWN=false

# Circuit breaker: if more than DEMO_BURST_THRESHOLD submissions arrive within
# DEMO_BURST_WINDOW_MINUTES, the demo auto-switches to canned results for
# DEMO_BREAKER_COOLDOWN_MINUTES, then heals itself.
DEMO_BURST_THRESHOLD=15
DEMO_BURST_WINDOW_MINUTES=10
DEMO_BREAKER_COOLDOWN_MINUTES=120

# Extra origins allowed to POST (comma-separated). Your own domain is always
# allowed; requests with no Origin/Referer (server-to-server, e.g. n8n) pass.
DEMO_ALLOWED_ORIGINS=

# Optional Slack webhook for breaker-tripped alerts.
SLACK_ALERT_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Firebase — client SDK (public, drives the live dashboard)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Firebase — Admin SDK (server-side writes + the quota counters)
# ---------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the whole key on one line, keeping the literal \n sequences.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# Google Sheets — for the bootstrap script only (npm run setup:sheet).
# n8n uses its OWN credential store for the Sheets nodes; these are separate.
# ---------------------------------------------------------------------------
GSHEETS_SPREADSHEET_ID=
GSHEETS_CLIENT_EMAIL=
GSHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# n8n webhooks (leave blank to run the app without n8n)
# ---------------------------------------------------------------------------
N8N_WEBHOOK_URL=http://localhost:5678/webhook/inbox-triage
N8N_APPROVE_WEBHOOK_URL=http://localhost:5678/webhook/approve-send
